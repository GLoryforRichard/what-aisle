NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# -----------------------------------------------------------------------------
# Crisp
# https://mksaas.com/docs/chatbox
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CRISP_WEBSITE_ID=""

# -----------------------------------------------------------------------------
# Cron Jobs (basic auth shared by all cron endpoints)
# https://mksaas.com/docs/cronjobs
#
# Schedule DAILY (e.g. crontab on the VM):
# - GET /api/distribute-credits      → credit distribution
# - GET /api/cron/store-maintenance  → store dunning backstop (suspend live
#   stores with payment failed > 7 days) + release pending_payment slug
#   locks older than 24h (expires their Stripe Checkout session first)
# Example crontab entry (runs at 04:00 every day):
#   0 4 * * * curl -fsS -u "$CRON_JOBS_USERNAME:$CRON_JOBS_PASSWORD" http://127.0.0.1:3002/api/cron/store-maintenance
# -----------------------------------------------------------------------------
CRON_JOBS_USERNAME=""
CRON_JOBS_PASSWORD=""

# -----------------------------------------------------------------------------
# AI
# https://mksaas.com/docs/ai
# -----------------------------------------------------------------------------
# DeepSeek: https://platform.deepseek.com/api_key
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=""
# -----------------------------------------------------------------------------
# OpenAI GPT: https://platform.openai.com/api-key
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# Web Content Analyzer (Firecrawl)
# https://firecrawl.dev/
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=""
