# -----------------------------------------------------------------------------
# Application BASE URL
# https://mksaas.com/docs/env#core-configuration
# For production, set to your domain, e.g. https://mksaas.com
# For development, set to http://localhost:3000 or any other port
# For payment test env, you can try https://hostc.dev for proxy
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# NEXT_PUBLIC_BASE_URL="https://xxx.hostc.dev/"

# -----------------------------------------------------------------------------
# Database
# https://mksaas.com/docs/database
# -----------------------------------------------------------------------------
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Better Auth
# https://mksaas.com/docs/auth
# Generate a random string for the secret key using `openssl rand -base64 32`
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=""

# -----------------------------------------------------------------------------
# Github OAuth
# https://mksaas.com/docs/auth#2-configure-github-oauth
# https://www.better-auth.com/docs/authentication/github
# Get Client information from https://github.com/settings/developers
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Google OAuth
# https://mksaas.com/docs/auth#3-configure-google-oauth
# https://www.better-auth.com/docs/authentication/google
# Get Client information from https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email / Newsletter (Resend)
# https://mksaas.com/docs/email
# https://mksaas.com/docs/newsletter
# Get API key from https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=""

# -----------------------------------------------------------------------------
# Newsletter (Beehiiv)
# https://mksaas.com/docs/newsletter
# Get API key from https://app.beehiiv.com/settings/integrations
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=""
BEEHIIV_PUBLICATION_ID=""

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 or S3-compatible service of your choice)
# https://mksaas.com/docs/storage
# Cloudflare R2: https://www.cloudflare.com/developer-platform/products/r2
#
# Also used for store-owner layout video uploads (PRD F-5 / task #6): the
# portal presigns a direct-to-R2 PUT (region 'auto', endpoint STORAGE_ENDPOINT,
# creds STORAGE_ACCESS_KEY_ID / STORAGE_SECRET_ACCESS_KEY). Videos are stored
# under the key prefix `stores/{slug}/video/`.
#
# NOTE: the 30-day retention of uploaded layout videos is an R2 bucket
# lifecycle-policy concern, NOT enforced by this app — configure an R2
# lifecycle rule to expire objects under `stores/*/video/` after 30 days.
# -----------------------------------------------------------------------------
STORAGE_REGION="auto"
STORAGE_BUCKET_NAME=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_URL=""

# Base domain for store subdomains ({slug}.<domain>). Defaults to whataisle.com.
NEXT_PUBLIC_STORE_BASE_DOMAIN="whataisle.com"

# -----------------------------------------------------------------------------
# Payment Provider
# Options: 'stripe' | 'creem' (default: 'stripe')
# Controls which payment provider is used and which price/product IDs are read
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYMENT_PROVIDER="stripe"

# -----------------------------------------------------------------------------
# Payment (Stripe)
# https://mksaas.com/docs/payment
# Get Stripe key and secret from https://dashboard.stripe.com
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Pro plan - monthly subscription
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=""
# Pro plan - yearly subscription
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=""
# Lifetime plan - one-time payment
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=""
# Credit package - basic
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_BASIC=""
# Credit package - standard
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_STANDARD=""
# Credit package - premium
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_PREMIUM=""
# Credit package - enterprise
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_ENTERPRISE=""
# What-Aisle plan - $99/mo subscription (Stripe recurring price)
NEXT_PUBLIC_STRIPE_PRICE_WHATAISLE_MONTHLY=""
# What-Aisle plan - $688 one-time setup fee (Stripe one-time price,
# added as an extra line item on the subscription checkout)
NEXT_PUBLIC_STRIPE_PRICE_WHATAISLE_SETUP=""

# -----------------------------------------------------------------------------
# What-Aisle internal API (portal <-> stores app, loopback only)
# Shared bearer secret; generate with `openssl rand -base64 32`
# -----------------------------------------------------------------------------
INTERNAL_API_SECRET=""
# Base URL of the stores app internal API (loopback in production)
STORES_INTERNAL_URL="http://127.0.0.1:3001"

# -----------------------------------------------------------------------------
# Payment (Creem) - alternative provider to Stripe
# https://docs.creem.io
# Set NEXT_PUBLIC_PAYMENT_PROVIDER='creem' to enable
# Get API key and webhook secret from https://creem.io dashboard
# CREEM_DEBUG=true uses test-api.creem.io (sandbox); false uses production
# -----------------------------------------------------------------------------
CREEM_DEBUG="true"
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# Pro plan - monthly subscription (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_PRO_MONTHLY=""
# Pro plan - yearly subscription (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_PRO_YEARLY=""
# Lifetime plan - one-time payment (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_LIFETIME=""
# Credit package - basic (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_BASIC=""
# Credit package - standard (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_STANDARD=""
# Credit package - premium (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_PREMIUM=""
# Credit package - enterprise (Creem product id)
NEXT_PUBLIC_CREEM_PRODUCT_CREDITS_ENTERPRISE=""

# -----------------------------------------------------------------------------
# Configurations
# -----------------------------------------------------------------------------
# Disable image optimization, check out next.config.ts for more details
# -----------------------------------------------------------------------------
DISABLE_IMAGE_OPTIMIZATION=false
# -----------------------------------------------------------------------------
# Run this website as demo website, in most cases, you should set this to false
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_WEBSITE=false

